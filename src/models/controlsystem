    def reconstruct_route(self, active_edges, depot, server):
        route = [depot]
        current = depot
        used_edges = set()
        while current != server:
            next_node = None
            for i, j in active_edges:
                if i == current and (i, j) not in used_edges:
                    next_node = j
                    used_edges.add((i, j))
                    break
            if next_node is None:
                break
            route.append(next_node)
            current = next_node
        return route